# Meta developer app credentials — required for Instagram/Facebook oEmbed thumbnails.
# Create an app at https://developers.facebook.com/apps, add "Instagram Graph API" /
# oEmbed Read product, then copy its App ID + App Secret here.
META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here

# --- Required only for /api/most-viewed (real view-count ranking) ---------------
# These must belong to YOUR OWN Instagram Business Account / Facebook Page — Meta's
# API has no way to return view counts for content you don't own. See README.md
# "Setting up Meta credentials" for exact steps to obtain each value below.

# Numeric ID of your Instagram Business/Creator Account (linked to a Facebook Page).
IG_BUSINESS_ACCOUNT_ID=your_ig_business_account_id_here
# Page Access Token with instagram_basic + instagram_manage_insights scopes.
# (This is usually the same token as FB_PAGE_ACCESS_TOKEN below.)
IG_ACCESS_TOKEN=your_ig_access_token_here

# Numeric ID of your Facebook Page.
FB_PAGE_ID=your_fb_page_id_here
# Page Access Token with pages_read_engagement + read_insights scopes.
FB_PAGE_ACCESS_TOKEN=your_fb_page_access_token_here
# ----------------------------------------------------------------------------------

# --- Newsroom feed (News.dc.html — /api/newsroom) --------------------------------
# Search query used to auto-discover news articles via Google News RSS (free,
# no signup/key needed).
NEWS_SEARCH_QUERY=Sobha Surendran

# X (Twitter) API v2 — OPTIONAL. Requires a paid Basic-tier (or higher)
# Developer account at developer.twitter.com (the free tier can't read a
# user's post history). Leave blank to skip X entirely — everything else in
# the newsroom feed (news articles, Facebook posts, Instagram posts) works
# fine without it.
X_BEARER_TOKEN=
X_USERNAME=SobhaBJP

# Hours a cached newsroom feed is considered fresh — also how often the
# built-in scheduled job (node-cron, hourly by default matches 1h) refreshes it.
NEWSROOM_CACHE_TTL_HOURS=1
# ----------------------------------------------------------------------------------

# --- Form submissions -> Google Sheets (Concern form + Volunteer form) -----------
# See README.md "Setting up Google Sheets" for exact steps to obtain these.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@your_project.iam.gserviceaccount.com
# Paste the private_key value from the downloaded JSON key file as-is (it
# contains literal \n sequences — leave them, don't convert to real newlines).
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
# The long ID in the sheet's URL: docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here
# ----------------------------------------------------------------------------------

# Port the API listens on
PORT=8787

# Hours a cached thumbnail is considered fresh before re-fetching
CACHE_TTL_HOURS=12

# Hours a cached view-count result is considered fresh before re-fetching
VIEWS_CACHE_TTL_HOURS=6
